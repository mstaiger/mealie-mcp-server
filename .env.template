# Mealie API Configuration
# Replace these values with your own Mealie instance details

# The base URL of your Mealie instance (including protocol and port if needed)
MEALIE_BASE_URL=https://your-mealie-instance.com

# Your Mealie API key
# Generate this from your Mealie account settings
MEALIE_API_KEY=your-mealie-api-key

LOG_LEVEL=INFO

# --- MCP transport configuration ---------------------------------------------
# Default transport is HTTP/SSE bound to 127.0.0.1:8765. Override these to
# change where the server listens, or set MEALIE_MCP_TRANSPORT=stdio (or pass
# --stdio) to fall back to the legacy stdio transport.
MEALIE_MCP_HOST=127.0.0.1
MEALIE_MCP_PORT=8765
# MEALIE_MCP_TRANSPORT=sse   # one of: sse, streamable-http, stdio
#
# The server refuses to bind MEALIE_MCP_HOST to a non-loopback address by
# default. To expose it on the network, you must (a) put a trusted auth/proxy
# layer in front of the server, then (b) set the opt-in flag below. The
# server exposes the full authority of MEALIE_API_KEY plus local-file upload
# tools to anything that can reach it.
# MEALIE_MCP_ALLOW_REMOTE_BIND=1

# --- File-path upload sandbox -------------------------------------------------
# Tools that take a filesystem path (upload_recipe_image_file, upload_recipe_
# asset_file, import_recipe_from_zip_file, import_recipe_from_image_files,
# upload_profile_image) are disabled unless MEALIE_MCP_UPLOAD_DIR points to
# an allowlisted directory. Paths are resolved with symlinks dereferenced and
# rejected if they escape the directory. Per-file size limit defaults to 50 MiB.
# MEALIE_MCP_UPLOAD_DIR=/path/to/uploads
# MEALIE_MCP_UPLOAD_MAX_BYTES=52428800
